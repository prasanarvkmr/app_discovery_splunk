{
  "name": "servicenow_incident_sla_pipeline",
  "max_concurrent_runs": 1,
  "schedule": {
    "quartz_cron_expression": "0 */2 * * * ?",
    "timezone_id": "UTC",
    "pause_status": "UNPAUSED"
  },
  "tasks": [
    {
      "task_key": "extract_from_splunk",
      "notebook_task": {
        "notebook_path": "/Repos/servicenow_pipeline/02_splunk_extraction",
        "source": "WORKSPACE"
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 0,
        "spark_conf": {
          "spark.databricks.cluster.profile": "singleNode",
          "spark.master": "local[*]"
        },
        "custom_tags": { "ResourceClass": "SingleNode" }
      },
      "timeout_seconds": 300,
      "max_retries": 2,
      "min_retry_interval_millis": 15000,
      "retry_on_timeout": true
    },
    {
      "task_key": "bronze_ingestion",
      "depends_on": [ { "task_key": "extract_from_splunk" } ],
      "notebook_task": {
        "notebook_path": "/Repos/servicenow_pipeline/03_bronze_ingestion",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 300,
      "max_retries": 2,
      "min_retry_interval_millis": 15000,
      "retry_on_timeout": true
    },
    {
      "task_key": "silver_transformations",
      "depends_on": [ { "task_key": "bronze_ingestion" } ],
      "notebook_task": {
        "notebook_path": "/Repos/servicenow_pipeline/04_silver_transformations",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "min_retry_interval_millis": 15000,
      "retry_on_timeout": true
    },
    {
      "task_key": "gold_aggregations",
      "depends_on": [ { "task_key": "silver_transformations" } ],
      "notebook_task": {
        "notebook_path": "/Repos/servicenow_pipeline/05_gold_aggregations",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 600,
      "max_retries": 2,
      "min_retry_interval_millis": 15000,
      "retry_on_timeout": true
    },
    {
      "task_key": "cross_pipeline_correlation",
      "depends_on": [ { "task_key": "gold_aggregations" } ],
      "notebook_task": {
        "notebook_path": "/Repos/cross_pipeline/02_build_correlation",
        "source": "WORKSPACE"
      },
      "timeout_seconds": 300,
      "max_retries": 1,
      "min_retry_interval_millis": 15000,
      "retry_on_timeout": true
    }
  ],
  "email_notifications": {
    "on_failure": [],
    "no_alert_for_skipped_runs": true
  },
  "tags": {
    "pipeline": "servicenow_incident_sla",
    "domain": "platform_analytics",
    "cadence": "2min"
  }
}
